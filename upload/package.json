{
  "name": "devcanvas",
  "version": "1.0.0",
  "private": true,
  "description": "GitHub-linked developer portfolio and activity hub",
  "main": "electron/main.js",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\" \"npm run dev:electron\"",
    "dev:web": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "npm --prefix server run dev",
    "dev:client": "npm --prefix client run dev",
    "dev:electron": "wait-on tcp:5173 tcp:3000 && electron .",
    "build:client": "npm --prefix client run build",
    "build": "npm run build:client && electron-builder",
    "start": "cross-env NODE_ENV=production electron ."
  },
  "devDependencies": {
    "concurrently": "^9.0.1",
    "cross-env": "^7.0.3",
    "electron": "^40.8.0",
    "electron-builder": "^26.0.12",
    "wait-on": "^8.0.3"
  },
  "build": {
    "appId": "com.devcanvas.app",
    "files": [
      "electron/**/*",
      "client/dist/**/*",
      "server/**/*",
      "package.json"
    ],
    "linux": {
      "target": [
        "AppImage"
      ],
      "category": "Development"
    }
  }
}
